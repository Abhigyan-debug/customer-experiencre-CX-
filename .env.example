# PulseCX Environment Configuration
# Copy this file to .env and fill in your values

# Flask Secret Key (generate a random one)
SECRET_KEY=your_secret_key_here

# Groq API Key for AI features
GROQ_API_KEY=your_groq_api_key_here

# Mail (forgot-password reset links). Optional - the app runs fine without
# these, "Forgot password" will just log a warning and quietly not send
# anything until they're set.
#
# Gmail example: MAIL_USERNAME is your Gmail address, MAIL_PASSWORD is a
# 16-character App Password (NOT your normal Gmail password) - generate one
# at https://myaccount.google.com/apppasswords (requires 2-Step Verification
# to be turned on first). Any other SMTP provider (SendGrid, Mailgun,
# Outlook, your own mail server, etc.) works too, just change MAIL_SERVER/
# MAIL_PORT accordingly.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_DEFAULT_SENDER=your_email@gmail.com
